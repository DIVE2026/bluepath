ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://bluepath:bluepath@db:5432/bluepath
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=*

# Server-only AI credentials. Never place these values in the Android project.
LLM_BASE_URL=https://your-openai-compatible-provider.example.com
LLM_API_KEY=replace-me
LLM_MODEL=bluepath-marine-lora
LLM_TIMEOUT_SECONDS=90
LLM_CONNECT_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=1
EMBEDDING_MODEL=text-embedding-model
EMBEDDING_DIMENSIONS=1536
# Set these to true in the submission/production environment to fail fast instead of silently using fallbacks.
REQUIRE_LLM=true
REQUIRE_EMBEDDINGS=true
REQUIRE_WEB_SEARCH=false

# Server-only HMAC key used to sign one-time exhibit QR payloads.
QR_SIGNING_SECRET=replace-with-an-independent-random-secret-of-at-least-32-characters
QR_TOKEN_MINUTES=20

YOUTUBE_API_KEY=replace-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Optional scheduled YouTube refresh. Use 0 to disable.
YOUTUBE_SYNC_HOURS=24
YOUTUBE_SYNC_QUERIES=해양 교육,해양 환경 교육,스마트 항만,자율운항선박
YOUTUBE_SYNC_MAX_RESULTS=10

# Optional official schedule feeds. Each URL should return a JSON array or {"items": [...]}.
# Supported item types are program, schedule, and event. Use 0 hours to disable automatic refresh.
SCHEDULE_FEED_URLS=
SCHEDULE_SYNC_HOURS=6
SCHEDULE_FEED_TIMEOUT_SECONDS=20

# Password reset links and optional SMTP delivery.
PASSWORD_RESET_BASE_URL=https://your-web-app.example.com/reset-password
PASSWORD_RESET_TOKEN_MINUTES=30
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=replace-me
SMTP_FROM_EMAIL=BluePath <mailer@example.com>
SMTP_USE_TLS=true

# Optional live web retrieval for AI career counseling and natural-language search.
# Supported providers: tavily, brave
WEB_SEARCH_PROVIDER=
WEB_SEARCH_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=15
WEB_CRAWL_MAX_CHARS=12000
