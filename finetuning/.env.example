# Dataset generation
BLUEPATH_DATASET_SEED=20260711

# Base model and reproducible training inputs
BLUEPATH_BASE_MODEL=Qwen/Qwen2.5-3B-Instruct
BLUEPATH_FINETUNE_OUTPUT=./finetuning/output/marine-lora
BLUEPATH_TRAIN_FILE=./finetuning/data/train.jsonl
BLUEPATH_VALIDATION_FILE=./finetuning/data/validation.jsonl
BLUEPATH_SEED=20260711

# LoRA / QLoRA settings
BLUEPATH_USE_4BIT=true
BLUEPATH_EPOCHS=3
BLUEPATH_LEARNING_RATE=0.0002
BLUEPATH_LR_SCHEDULER=cosine
BLUEPATH_WARMUP_RATIO=0.05
BLUEPATH_WEIGHT_DECAY=0.01
BLUEPATH_MAX_GRAD_NORM=1.0
BLUEPATH_LORA_R=16
BLUEPATH_LORA_ALPHA=32
BLUEPATH_LORA_DROPOUT=0.05
BLUEPATH_LORA_TARGETS=all-linear
BLUEPATH_MAX_SEQ_LENGTH=2048
BLUEPATH_TRAIN_BATCH=1
BLUEPATH_EVAL_BATCH=1
BLUEPATH_GRAD_ACCUM=8
BLUEPATH_PACKING=false
BLUEPATH_SAVE_TOTAL_LIMIT=2
BLUEPATH_REPORT_TO=none
BLUEPATH_RUN_NAME=bluepath-marine-sft
BLUEPATH_ASSISTANT_ONLY_LOSS=false
BLUEPATH_EOS_TOKEN=<|im_end|>
BLUEPATH_DATASET_NUM_PROC=1
BLUEPATH_EARLY_STOPPING_PATIENCE=2
BLUEPATH_EARLY_STOPPING_THRESHOLD=0.0
BLUEPATH_AUTO_RESUME=false
# BLUEPATH_RESUME_CHECKPOINT=auto

# OpenAI-compatible serving
BLUEPATH_SERVED_MODEL=bluepath-marine
BLUEPATH_ADAPTER_PATH=./finetuning/output/marine-lora
BLUEPATH_MODEL_API_KEY=replace-with-a-long-random-value
BLUEPATH_SERVE_4BIT=true

# Candidate evaluation
BLUEPATH_EVAL_BASE_URL=http://localhost:8001/v1
BLUEPATH_EVAL_MODEL=bluepath-marine
BLUEPATH_EVAL_API_KEY=replace-with-the-same-serving-key
BLUEPATH_EVAL_TIMEOUT_SECONDS=120
BLUEPATH_EVAL_RETRIES=2
BLUEPATH_EVAL_MAX_TOKENS=1800
BLUEPATH_MIN_EVAL_RATE=0.85
BLUEPATH_MIN_CATEGORY_RATE=0.75

# Optional baseline endpoint for before/after comparison
BLUEPATH_BASELINE_URL=http://localhost:8002/v1
BLUEPATH_BASELINE_MODEL=base-model-name
BLUEPATH_BASELINE_API_KEY=
BLUEPATH_MIN_PASS_RATE_DELTA=0.0
BLUEPATH_CATEGORY_REGRESSION_TOLERANCE=0.0
BLUEPATH_MAX_REGRESSED_CATEGORIES=0
